rules_version = '2';

// ============================================================
// Soundcheck — multi-band access control
//
// Model: each band is one document at boards/{bandId} containing:
//   memberEmails: ["a@x.com", ...]            (array, for querying)
//   access:       { "a@x.com": "owner"|"editor"|"viewer", ... }
//
// Roles:
//   owner  - edit everything + manage members + delete the band
//   editor - edit content, but NOT membership
//   viewer - read only
//
// The app admin (you) is the ONLY account that can create new bands.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // >>> SET THIS to the app admin's email (must match ADMIN_EMAIL in the app) <<<
    function adminEmail() { return 'ofiralon10@gmail.com'; }

    function email()    { return request.auth.token.email; }
    function signedIn() { return request.auth != null && email() != null; }
    function isAdmin()  { return signedIn() && email() == adminEmail(); }

    match /boards/{bandId} {
      function isMember() { return signedIn() && (email() in resource.data.memberEmails); }
      function role()     { return resource.data.access[email()]; }
      function membershipUnchanged() {
        return request.resource.data.memberEmails == resource.data.memberEmails
            && request.resource.data.access == resource.data.access;
      }

      // READ: any member of this band. Admin can read all bands (for support).
      allow read: if isAdmin() || isMember();

      // CREATE: app admin only. New doc must carry the access fields.
      allow create: if isAdmin()
                    && request.resource.data.memberEmails is list
                    && request.resource.data.access is map;

      // UPDATE: admin or owner can change anything (incl. membership);
      //         editor can change content but NOT the member list.
      allow update: if isAdmin()
                    || (isMember() && role() == 'owner')
                    || (isMember() && role() == 'editor' && membershipUnchanged());

      // DELETE: admin or an owner.
      allow delete: if isAdmin() || (isMember() && role() == 'owner');
    }

    // Push-notification device tokens for the always-on manager. Owner-only
    // for now: only the admin can register/read their own devices. Cloud
    // Functions use the Admin SDK and bypass these rules.
    match /notifyTokens/{token} {
      allow read, write, delete: if isAdmin();
    }

    // Manager scheduler bookkeeping (sent reminders, last weekly time).
    // Written only by Cloud Functions (Admin SDK); locked to admin otherwise.
    match /managerState/{bandId} {
      allow read, write: if isAdmin();
    }

    // Manager chat transcript. Read/written ONLY by the managerChat Cloud
    // Function (Admin SDK, which bypasses these rules). Clients reach it solely
    // through the callable, which enforces the allowlist — so deny direct access.
    match /managerChat/{bandId} {
      allow read, write: if false;
    }

    // Telegram link codes: the owner creates a one-time code to link their
    // Telegram; the webhook (Admin SDK) reads/deletes it.
    match /telegramLinks/{code} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    // Telegram linked-chat registry, written only by the webhook (Admin SDK).
    // Owner can read to show linked status (owner-only for now).
    match /telegramChats/{bandId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
